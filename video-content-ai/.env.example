# ── Server ───────────────────────────────────────────────────────
VCAI_HOST=0.0.0.0
VCAI_PORT=8501
VCAI_RELOAD=true

# ── Data persistence ────────────────────────────────────────────
# VCAI_DATA_DIR=./data

# ── Database ────────────────────────────────────────────────────
# Default: sqlite:///data/vcai.db (auto-created on first run)
# VCAI_DATABASE_URL=sqlite:///data/vcai.db

# ── Auth / JWT ──────────────────────────────────────────────────
# IMPORTANT: change this in production!
VCAI_JWT_SECRET=change-me-in-production
VCAI_JWT_EXPIRE_HOURS=24

# ── LLM Provider ────────────────────────────────────────────────
# Options: ollama (default), openai, anthropic, company_gpt
VCAI_LLM_PROVIDER=ollama

# Ollama settings (when provider=ollama)
OLLAMA_BASE_URL=http://localhost:11434
VCAI_DEFAULT_MODEL=llama3
VCAI_VISION_MODEL=llava
VCAI_MAX_WORKERS=5

# OpenAI settings (when provider=openai)
# OPENAI_API_KEY=sk-...
# VCAI_DEFAULT_MODEL=gpt-4o-mini

# Anthropic settings (when provider=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# VCAI_DEFAULT_MODEL=claude-sonnet-4-20250514

# Company GPT settings (when provider=company_gpt)
# Uses internal AI Framework proxy (ai-framework1)
# COMPANY_GPT_ENDPOINT=https://ai-framework1:8085
# COMPANY_GPT_API_KEY=your-api-key-here
# COMPANY_GPT_CALLER=yourntnet@amdocs.com
# COMPANY_GPT_VERIFY_SSL=false
# VCAI_DEFAULT_MODEL=gpt-4.1

# ── Vector Search (RAG) ──────────────────────────────────────────
# VCAI_EMBEDDING_MODEL=nomic-embed-text

# ── Whisper ─────────────────────────────────────────────────────
VCAI_WHISPER_MODEL=base
VCAI_LANGUAGE=en

# ── Speech-to-text: Whisper (local) or AWS Transcribe ─────────────
# VCAI_STT_PROVIDER=whisper
# VCAI_STT_PROVIDER=aws
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# VCAI_AWS_TRANSCRIBE_BUCKET=your-bucket-name
# VCAI_AWS_TRANSCRIBE_OUTPUT_PREFIX=transcripts/
# VCAI_AWS_TRANSCRIBE_POLL_TIMEOUT_SEC=3600

# yt-dlp: max seconds to wait on idle socket reads (YouTube CDN); default in code is 120 if unset
# VCAI_YTDLP_SOCKET_TIMEOUT=120

# ── Rate Limiting ────────────────────────────────────────────────
# VCAI_RATE_LIMIT=60            # Global requests per minute per IP
# VCAI_RATE_LIMIT_HEAVY=10      # Limit for heavy endpoints (transcribe, generate, batch, retone, analyze)

# ── Transcript processing ──────────────────────────────────────
VCAI_CONDENSE_THRESHOLD=5000
VCAI_CONDENSE_CHUNK=2000
VCAI_CHUNK_DURATION=300
VCAI_MIN_CHUNK_DURATION=600

# CodexVid pipeline: parallel faster-whisper (20–30s slices)
# VCAI_CODEXVID_CHUNK_SEC=25
# VCAI_CODEXVID_PARALLEL_WORKERS=4
# Legacy env names VCAI_TEACHER_CHUNK_SEC / VCAI_TEACHER_PARALLEL_WORKERS still honored if unset above
